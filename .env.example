# Copy to .env and fill in. .env is gitignored. Secrets in k8s go via Secret, not here.

# ---- RPC / watcher-svc — Phase 2 ----
RPC_WSS_URL=wss://your-polygon-endpoint-with-websocket   # required; must be ws/wss (log subscriptions)
# LEADERBOARD_GRPC_ADDR=leaderboard:50051                # watcher dials leaderboard-svc here
# WATCHER_DB_PATH=watcher.db                             # persists last_processed_block

# ---- Telegram (notifier-svc) — Phase 4 ----
TELEGRAM_BOT_TOKEN=
# ALERT_DEDUP_TTL=24h        # notifier: suppress re-emits of the exact same fill
# ALERT_COOLDOWN=15m         # notifier: collapse a whale's repeated trades on one market+side (0=off)
TELEGRAM_CHAT_ID=
# Position-exit alerts (read-only, public): set your PUBLIC Polymarket wallet to be
# alerted when a tracked whale exits a market you hold. Empty = disabled.
# USER_WALLET=
# DATA_API_BASE=https://data-api.polymarket.com
# MY_POSITIONS_POLL_INTERVAL=5m

# ---- Execution policy (strategy/trader) ----
# approval | auto | auto_below:<usd>
EXECUTION_MODE=approval

# ---- Leaderboard (leaderboard-svc) — Phase 1 ----
LEADERBOARD_WINDOW=30d         # 1d | 7d | 30d | all
LEADERBOARD_METRIC=pnl         # pnl | volume
LEADERBOARD_TOP_N=30           # track the top 30 performing wallets
# LEADERBOARD_API_BASE=https://lb-api.polymarket.com
# LEADERBOARD_DB_PATH=watchset.db
# LEADERBOARD_GRPC_ADDR=:50051

# Consistency-stats selection (strict quality gates; auto-refreshed daily). A
# wallet must clear ALL gates to be tracked — with strict gates the watchset may
# be far fewer than TOP_N (quality over count).
# LEADERBOARD_DATA_API_BASE=https://data-api.polymarket.com
# STATS_MIN_WIN_RATE=0.90        # >=90% win rate over resolved markets
# STATS_MIN_PORTFOLIO_USD=100000 # >=$100k portfolio value
# STATS_MIN_RESOLVED=20          # >=20 resolved markets (so 90% win rate is meaningful)
# STATS_MIN_REALIZED_PNL=0       # raise to require proven net profit (e.g. 50000)
# STATS_REQUIRE_FRESH=true       # exclude cooling-off wallets from the watchset
# SKILL_SHRINKAGE_K=200          # skill: ~resolved markets before own ROI outweighs the prior
# CANDIDATE_TOPK=50              # top-K per window (7d/30d/all) into the candidate pool
# STATS_MAX_CANDIDATES=100       # cap on wallets crawled per refresh
# STATS_MAX_ACTIVITY_ROWS=3000  # cap on /activity rows fetched per wallet
# STATS_CONCURRENCY=8           # concurrent wallet crawls (bounded worker pool)
# STATS_REFRESH_INTERVAL=24h    # how often the watchset is rebuilt (daily)

# ---- Consensus (consensus-svc) — multiple tracked wallets converge on one bet ----
# CONSENSUS_MIN_WALLETS=3        # distinct tracked wallets on the same token+side to fire
# CONSENSUS_WINDOW=6h            # rolling window for the cohort
# CONSENSUS_DB_PATH=consensus.db
# CONSENSUS_QUEUE_GROUP=consensus

# notifier dials leaderboard for whale track-record stats in alerts:
# LEADERBOARD_GRPC_ADDR=leaderboard:50051   # (notifier client; also the leaderboard bind addr)

# ---- Polymarket trading (trader-svc) — Phase 7 ⚠️ real money / US-geofenced ----
# TRADER_PRIVATE_KEY is injected via k8s Secret, NEVER placed in this file.
# Derive the L2 creds: TRADER_PRIVATE_KEY=... make trader-keys   (see docs/TRADER-SETUP.md)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# TRADER_FUNDER_ADDRESS=0x...          # signer EOA (POLY_ADDRESS)
# TRADER_MAKER_ADDRESS=0x...           # proxy/Safe holding funds
# TRADER_SIGNATURE_TYPE=1              # 1 proxy | 2 gnosis | 0 EOA
# TRADER_EXCHANGE_ADDRESS=0xe111180000d2663c0091e4f400237545b87b996b  # CTF (default) or NegRisk

# ---- Risk caps (trader-svc enforced, independent of strategy) ----
MAX_USD_PER_TRADE=25
MAX_USD_PER_DAY=200
MAX_OPEN_EXPOSURE_USD=500
MAX_SLIPPAGE_CENTS=3

# ---- NATS ----
NATS_URL=nats://nats:4222

# ---- Strategy sizing engine (Phase B; off by default — see docs/DEPLOY-trader-activation.md) ----
# STRATEGY_SIZING_ENABLED=false  # set true only when eligible to trade
# BANKROLL_USD=10000             # required (>0) when sizing enabled
# KELLY_FRACTION=0.25            # quarter-Kelly to start
